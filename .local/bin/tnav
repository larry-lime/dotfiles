#!/bin/zsh

# NOTE: Something good would be for me to, once zoxide has my filepath dirs saved, add them to the list instead of manually passing the dirs

# export FZF_DEFAULT_OPTS="--color=bg+:#363a4f,bg:#24273a,spinner:#f4dbd6,hl:#ed8796 --color=fg:#cad3f5,header:#ed8796,info:#c6a0f6,pointer:#f4dbd6 --color=marker:#f4dbd6,fg+:#cad3f5,prompt:#c6a0f6,hl+:#ed8796"

# ============================================================================
# Config
# ============================================================================

# Required CLI tools, formatted as "binary:brew-formula". Missing binaries
# are auto-installed via brew on launch.
DEPS=(tmux:tmux sesh:sesh sd:sd fd:fd rg:ripgrep fzf-tmux:fzf zoxide:zoxide)

# Search roots — fd recursively searches these. Hidden roots (e.g.
# ~/.dotfiles) must be listed explicitly because fd skips dotdirs by default.
DIRS=("$HOME" "$HOME/.dotfiles")

# Cap fd's traversal depth. Higher values surface more deeply nested files
# but slow down the picker and delay cleanup when fzf exits (fd has to drain
# its walk before SIGPIPE kills it).
FD_MAX_DEPTH=5

# Directories fd should skip entirely. ~/Library is huge on macOS and rarely
# something we want to navigate into.
FD_EXCLUDES=(-E Library)

# fzf-tmux popup geometry passed to `-p` (width,height as percentages).
FZF_POPUP_SIZE="40%,70%"

# Flags shared across all three pickers. Per-picker flags (--exact,
# --border-label) are still set inline.
FZF_BASE_OPTS=(--reverse --no-sort --prompt '🔎 ' --expect 'alt-enter,enter')

# ============================================================================

for dep in "${DEPS[@]}"; do
  bin=${dep%:*}
  formula=${dep#*:}
  if ! command -v "$bin" >/dev/null 2>&1; then
    echo "tnav: missing '$bin' — installing $formula via brew..."
    brew install "$formula"
  fi
done

nav_tmux() {
  local windows=$(tmux list-windows -a -F "#S:#W" | sd '^' '[w] ')
  local zoxide_dirs=$(sesh list --zoxide | sd '^' '[z] ')
  local sessions=$(sesh list --tmux --config |  sd '^' '[s] ')

  {
    echo -e "$sessions\n$windows\n$zoxide_dirs"
    fd . --max-depth "$FD_MAX_DEPTH" "${FD_EXCLUDES[@]}" "$@" | sd '^' '[p] ' | sd "$HOME" '~'
  } | rg -v '^\[w\] $|^\[z\] $|^\[s\] $|^\[p\] $' |
    fzf-tmux -p "$FZF_POPUP_SIZE" "${FZF_BASE_OPTS[@]}" --border-label ' Tnav Sessions' |
    sd '.*] ' '' |
    xargs echo
}

nav_window() {
  local windows=$(tmux list-windows -a -F "#S:#I:#W" | sd '^' '[w] ')
  local zoxide_dirs=$(sesh list --zoxide | sd '^' '[z] ')

  {
    echo -e "$windows\n$zoxide_dirs"
    fd . --max-depth "$FD_MAX_DEPTH" "${FD_EXCLUDES[@]}" "$@" | sd '^' '[p] ' | sd "$HOME" '~'
  } | rg -v '^\[w\] $|^\[z\] $|^\[s\] $|^\[p\] $' |
    fzf-tmux -p "$FZF_POPUP_SIZE" "${FZF_BASE_OPTS[@]}" --border-label ' Tnav Windows' |
    sd '.*] ' '' |
    xargs echo
}

nav() {
  local zoxide_dirs=$(sesh list --zoxide | sd '^' '[z] ')

  {
    echo -e "$zoxide_dirs"
    fd . --max-depth "$FD_MAX_DEPTH" "${FD_EXCLUDES[@]}" "$@" | sd '^' '[p] ' | sd "$HOME" '~'
  } | rg -v '^\[w\] $|^\[z\] $|^\[s\] $|^\[p\] $' |
    fzf-tmux -p "$FZF_POPUP_SIZE" "${FZF_BASE_OPTS[@]}" --exact --border-label ' Tnav Shell' |
    sd '.*] ' '' |
    xargs echo
}

# Check last argument value.
LAST_ARG="${@:$#}"

if [[ -z $1 ]]; then
  read -r KEYPRESS BASE_PATH <<<"$(nav "${DIRS[@]}" | sd '~' $HOME)"

elif [[ $LAST_ARG =~ ^(--window|w)$ ]]; then
	RUN_WINDOWS=true
  read -r KEYPRESS BASE_PATH <<<"$(nav_window "${DIRS[@]}" | sd '~' $HOME)"

elif [[ $LAST_ARG =~ ^(--tmux)$ ]]; then
	RUN_TMUX=true
  read -r KEYPRESS BASE_PATH <<<"$(nav_tmux "${DIRS[@]}" | sd '~' $HOME)"

elif [[ $LAST_ARG =~ ^(--relative|-r)$ ]]; then
  cd "$(fd -t d | fzf-tmux -p 40%,70% --reverse --layout=reverse)"
else
	echo "Invalid argument passed"
fi

if [ -z $BASE_PATH ]; then
	return
fi

# TODO: Here, set my current session and window as the last session
if [[ "$RUN_TMUX" = true ]]; then
  read -r last_session last_window <<<"$(tmux display-message -p '#S:#W' | sd ':' ' ')"
  tmux set-environment -g LAST_SESSION "$last_session"
  tmux set-environment -g LAST_WINDOW "$last_window"
fi

BASE_NAME=$(basename $BASE_PATH)
PARENT_PATH=$(dirname $BASE_PATH)
PARENT_NAME=$(basename $PARENT_PATH | tr -d '.')

open_directory() {
	if [ "$KEYPRESS" = "enter" ]; then
    zoxide add $BASE_PATH
		if [[ "$RUN_TMUX" = true ]]; then
      sesh connect -c $EDITOR $BASE_PATH
    elif [[ "$RUN_WINDOWS" = true ]]; then
      WINDOW_ID=$(tmux new-window -n "$BASE_NAME" -c "$BASE_PATH" -P -F "#{window_id}")
      tmux send-keys -t "$WINDOW_ID" 'nvim' C-m
      tmux select-window -t "$WINDOW_ID"
    else
			# If we're in a tmux pane (not --tmux or --window mode), send commands to current pane
			if [[ -n "$TMUX" ]]; then
				# Check if nvim is running in the current pane
				local pane_cmd=$(tmux display-message -p -t "$TMUX_PANE" -F "#{pane_current_command}")
				if [[ "$pane_cmd" == "nvim" ]] || [[ "$pane_cmd" == "vim" ]]; then
					# Exit nvim first
					tmux send-keys -t "$TMUX_PANE" Escape ":qa!" C-m
					sleep 0.1
				fi
				tmux send-keys -t "$TMUX_PANE" "cd $BASE_PATH && $EDITOR" C-m
			else
				cd $BASE_PATH && $EDITOR
			fi
		fi
	elif [[ "$KEYPRESS" = "alt-enter" ]]; then
    zoxide add $BASE_PATH
		if [[ "$RUN_TMUX" = true ]]; then
      sesh connect $BASE_PATH
    elif [[ "$RUN_WINDOWS" = true ]]; then
      tmux new-window -n $BASE_NAME -c $BASE_PATH
		else
			# If we're in a tmux pane (not --tmux or --window mode), send commands to current pane
			if [[ -n "$TMUX" ]]; then
				# Check if nvim is running in the current pane
				local pane_cmd=$(tmux display-message -p -t "$TMUX_PANE" -F "#{pane_current_command}")
				if [[ "$pane_cmd" == "nvim" ]] || [[ "$pane_cmd" == "vim" ]]; then
					# Exit nvim first
					tmux send-keys -t "$TMUX_PANE" Escape ":qa!" C-m
					sleep 0.1
				fi
				tmux send-keys -t "$TMUX_PANE" "cd $BASE_PATH" C-m
			else
				cd $BASE_PATH
			fi
		fi
	else
		return
	fi
}

open_file() {
	if [ "$KEYPRESS" = "enter" ]; then
		if [[ "$RUN_TMUX" = true ]]; then
      sesh connect -c "$EDITOR $BASE_NAME" $PARENT_PATH
    elif [[ "$RUN_WINDOWS" = true ]]; then
      WINDOW_ID=$(tmux new-window -n "$BASE_NAME" -c "$PARENT_PATH" -P -F "#{window_id}")
      tmux send-keys -t "$WINDOW_ID" "nvim $BASE_NAME" C-m
      tmux select-window -t "$WINDOW_ID"
		else
			# If we're in a tmux pane (not --tmux or --window mode), send commands to current pane
			if [[ -n "$TMUX" ]]; then
				# Check if nvim is running in the current pane
				local pane_cmd=$(tmux display-message -p -t "$TMUX_PANE" -F "#{pane_current_command}")
				if [[ "$pane_cmd" == "nvim" ]] || [[ "$pane_cmd" == "vim" ]]; then
					# Exit nvim first
					tmux send-keys -t "$TMUX_PANE" Escape ":qa!" C-m
					sleep 0.1
				fi
				tmux send-keys -t "$TMUX_PANE" "cd $PARENT_PATH && $EDITOR $BASE_NAME" C-m
			else
				cd $PARENT_PATH && $EDITOR $BASE_NAME
			fi
		fi
	elif [[ "$KEYPRESS" = "alt-enter" ]]; then
		if [[ "$RUN_TMUX" = true ]]; then
      sesh connect $PARENT_PATH
    elif [[ "$RUN_WINDOWS" = true ]]; then
      tmux new-window -n $BASE_NAME -c $PARENT_PATH
		else
			# If we're in a tmux pane (not --tmux or --window mode), send commands to current pane
			if [[ -n "$TMUX" ]]; then
				# Check if nvim is running in the current pane
				local pane_cmd=$(tmux display-message -p -t "$TMUX_PANE" -F "#{pane_current_command}")
				if [[ "$pane_cmd" == "nvim" ]] || [[ "$pane_cmd" == "vim" ]]; then
					# Exit nvim first
					tmux send-keys -t "$TMUX_PANE" Escape ":qa!" C-m
					sleep 0.1
				fi
				tmux send-keys -t "$TMUX_PANE" "cd $PARENT_PATH" C-m
			else
				cd $PARENT_PATH
			fi
		fi
	else
		return
	fi
}

if echo "$(sesh list --tmux --config)" | rg -q "^$BASE_PATH$"; then
  sesh connect $BASE_PATH
elif [[ "$BASE_PATH" == *":"* ]]; then
  # Check if it's a window reference (session:index:name format)
  if [[ "$BASE_PATH" == *":"*":"* ]]; then
    IFS=':' read -r session window_index window_name <<< "$BASE_PATH"
    sesh connect $session
    tmux select-window -t $window_index
  else
    # Fallback for old format (session:window)
    IFS=':' read -r session window <<< "$BASE_PATH"
    sesh connect $session
    tmux select-window -t $window
  fi
  return
elif [ -d $BASE_PATH ]; then
  open_directory
else
  open_file
fi
